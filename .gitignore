# ──────────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
pnpm-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ──────────────────────────────────────────────────────────────────────────
