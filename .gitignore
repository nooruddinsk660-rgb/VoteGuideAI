# ──────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.exe
.AppleDouble
.LSOverride

# ──────────────────────────────────────────────────────────────────────────
# 🛠️ IDE & Editor Files
# ──────────────────────────────────────────────────────────────────────────
# VS Code
.vscode/
*.code-workspace
.history/

# WebStorm / IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.vim
.vim/
.netrwhist
Session.vim

# Atom
.atom/

# General
.editorconfig
*.bak
*.tmp
.#*

# ──────────────────────────────────────────────────────────────────────────
# 📝 Logs & Temporary Files
# ──────────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*
*.swp
*.swo
*~

# ──────────────────────────────────────────────────────────────────────────
# 🧪 Testing & Coverage
# ──────────────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
.mocha.timeout.json
test-results/

# ──────────────────────────────────────────────────────────────────────────
