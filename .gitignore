# ═══════════════════════════════════════════════════════════════════════════
# VoteGuide Project - Root .gitignore
# ═══════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────
# 🔐 Environment & Secrets (CRITICAL - Never commit!)
# ──────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
.secret

# ──────────────────────────────────────────────────────────────────────────
# 💾 OS & System Files
# ──────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.exe
.AppleDouble
.LSOverride
desktop.ini

# ──────────────────────────────────────────────────────────────────────────
# 🛠️ IDE & Editor Files
# ──────────────────────────────────────────────────────────────────────────
# VS Code
.vscode/
*.code-workspace
.history/

# WebStorm / IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.vim
.vim/
.netrwhist
Session.vim

# Atom
.atom/

# General
.editorconfig
*.bak
*.tmp
.#*

# ──────────────────────────────────────────────────────────────────────────
# 📦 Dependencies & Package Manager
# ──────────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
pnpm-error.log*
.pnpm-store/
package-lock.json
yarn.lock
pnpm-lock.yaml
lerna-debug.log

# ──────────────────────────────────────────────────────────────────────────
# 📝 Logs & Temporary Files
# ──────────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*
*.swp
*.swo
*~

# ──────────────────────────────────────────────────────────────────────────
# 🏗️ Build & Distribution
# ──────────────────────────────────────────────────────────────────────────
dist/
build/
out/
coverage/
.cache/
.next/
.nuxt/

# ──────────────────────────────────────────────────────────────────────────
# 🧪 Testing & Coverage
# ──────────────────────────────────────────────────────────────────────────
.nyc_output/
*.lcov
.mocha.timeout.json
test-results/
test-data/

# ──────────────────────────────────────────────────────────────────────────
# 🌐 Local Development
# ──────────────────────────────────────────────────────────────────────────
.local
.vscode-test/
.nodemon.json
.forever/

# ──────────────────────────────────────────────────────────────────────────
# 📦 Runtime & Process Files
# ──────────────────────────────────────────────────────────────────────────
*.pid
*.seed
*.pid.lock
*.rdb

# ──────────────────────────────────────────────────────────────────────────
# 🎯 Project-Specific (VoteGuide)
# ──────────────────────────────────────────────────────────────────────────
temp/
tmp/
uploads/
.test-results/

# ──────────────────────────────────────────────────────────────────────────
# 📁 Local Directories (Never commit)
# ──────────────────────────────────────────────────────────────────────────
.local/
local/
.vscode/

# ──────────────────────────────────────────────────────────────────────────
# ⚠️ Keep These (Important Project Files)
# ──────────────────────────────────────────────────────────────────────────
!.gitkeep
!README.md
!.env.example
!.gitignore
!package.json
!package-lock.json