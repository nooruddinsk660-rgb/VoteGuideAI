# ──────────────────────────────────────────────────────────────────────────
*.map
*.tgz
*.tar.gz

# ──────────────────────────────────────────────────────────────────────────
# 🎯 Project-Specific (VoteGuide Frontend)
# ──────────────────────────────────────────────────────────────────────────
temp/
tmp/
uploads/
.test-results/
*.swp

# ──────────────────────────────────────────────────────────────────────────
# ⚠️ Keep These (Important Project Files)
# ──────────────────────────────────────────────────────────────────────────
